
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int         @id @default(autoincrement())
  email     String      @unique
  name      String?
  address   String?
  status    String      @default("active")
  role      String      @default("customer")
  createdAt DateTime
  medicines Medicines[]
}

model Medicines {
  id           Int          @id @default(autoincrement())
  title        String
  price        Float
  stock        Int
  manufacturer String
  description  String
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime
  updatedAt    DateTime
  reviews      Reviews[]
  categories   Categories[]
  orders       Orders[]
}

model Orders {
  id               Int       @id @default(autoincrement())
  productId        Int
  product          Medicines @relation(fields: [productId], references: [id], onDelete: Cascade)
  cashOnDelivery   Boolean
  shipping_Address String
  createdAt        DateTime
}

model Reviews {
  id        Int       @id @default(autoincrement())
  productId Int
  product   Medicines @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  createdAt DateTime
}

model Categories {
  id        Int       @id @default(autoincrement())
  productId Int
  product   Medicines @relation(fields: [productId], references: [id])
}
